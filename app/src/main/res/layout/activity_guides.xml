<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9E7E6"
    android:padding="16dp"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/iv_emergency_icon"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_emergency"
                android:contentDescription="App Logo" />

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/back"
                android:background="@android:color/transparent"
                android:layout_alignParentEnd="true"
                android:contentDescription="Back button" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Aid Guides"
                android:textColor="#000"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_centerHorizontal="true" />
        </RelativeLayout>

        <!-- Search Bar -->
        <EditText
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Search Guides..."
            android:paddingStart="16dp"
            android:paddingEnd="16dp"

            android:drawablePadding="8dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/guides_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Performing CPR"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CPR is a lifesaving procedure performed when someone's breathing or heartbeat has stopped..."
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/link_cpr_video"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch CPR on YouTube"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/link_cpr_article"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read CPR Articles"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Choking Guide -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Helping Someone Who is Choking"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="If someone is choking, encourage them to cough. If that doesn't work, use back blows and abdominal thrusts..."
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <!-- Choking Links -->
                <TextView
                    android:id="@+id/link_choking_video"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch Choking on YouTube"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/link_choking_article"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read Choking Articles"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Struggling with an Anxiety Attack"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anxiety attacks can feel overwhelming, but learning to breathe and stay calm is essential..."
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/link_anxiety_video"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch Anxiety on YouTube"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/link_anxiety_article"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read Anxiety Articles"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Having an Allergic Reaction"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="If you're having an allergic reaction, avoid the trigger and seek medical help immediately if symptoms worsen..."
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/link_allergic_video"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch Allergic Reaction on YouTube"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/link_allergic_article"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read Allergic Reaction Articles"
                    android:textColor="#1E88E5"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
